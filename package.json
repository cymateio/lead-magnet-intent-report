{
  "name": "signal-research-engine",
  "version": "1.0.0",
  "description": "Standalone plug-and-play deep-research engine: domain/email in, high-intent companies + contacts out.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "research",
    "signals",
    "icp",
    "outbound"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@trigger.dev/sdk": "4.4.6",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "googleapis": "^173.0.0",
    "nodemailer": "^6.9.15"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "@types/nodemailer": "^6.4.16",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
