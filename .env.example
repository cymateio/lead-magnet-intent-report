# --- Claude (Anthropic) — Steps 1-3 research + web search ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
# Override only if your account uses a different web-search tool version
# CLAUDE_WEBSEARCH_TOOL=web_search_20260209
# Depth knobs for the Step 3 deep discovery (higher = more thorough, but each
# web-search call runs longer). 12 surfaces enough companies to consistently yield 2-3
# after the no-contact filter; lower toward ~6 only on flaky local networks that drop long calls.
CLAUDE_DEEP_SEARCH_USES=12
CLAUDE_MAX_RESUMES=12             # how many times to resume the web-search loop
# CLAUDE_REQUEST_TIMEOUT_MS=1200000  # per-call safety ceiling (default 20 min)

# --- AI-Ark (contact enrichment via MCP) ---
# Email resolution uses AI-Ark's MCP (email_finder -> email_finder_results).
# The token goes in the URL query (?token=YOUR-API-KEY).
AIARK_MCP_URL=https://api.ai-ark.com/v1/mcp?token=YOUR-API-KEY
AIARK_MCP_TRANSPORT=http          # "http" (Streamable HTTP) or "sse"
# AIARK_API_KEY=                  # optional; only if the server also wants a header
# AIARK_MCP_AUTH_HEADER=X-TOKEN   # header name used when AIARK_API_KEY is set
# Tuning (optional)
AIARK_CONTACTS_PER_COMPANY=3      # emailable contacts to keep per company
AIARK_PEOPLE_SIZE=5               # people to look up per company (some won't have emails)
AIARK_EMAIL_TIMEOUT_MS=60000      # max wait for the async email-finder job per company

# --- Email delivery (configurable SMTP; defaults to Gmail's host/port) ---
# For the dedicated report sender, point these at report@<your-domain>'s mailbox.
# On Google Workspace, SMTP_PASS is a 16-char App Password (needs 2-Step Verification).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=report@your-domain.com
SMTP_PASS=
MAIL_FROM=report@your-domain.com
# (Legacy GMAIL_USER / GMAIL_APP_PASSWORD are still honored as a fallback.)

# --- API auth (optional) ---
# Leave WEBHOOK_SECRET unset for an open API. Set it to require the
# X-Webhook-Secret header on every /api/research call.
# WEBHOOK_SECRET=choose-a-long-random-secret

# --- Server ---
PORT=3000
# How long finished jobs stay fetchable in memory before cleanup
# JOB_TTL_MS=21600000              # 6 hours

# --- Branding (optional) ---
# The logo is served by the app from src/web/cymate-logo.png (shows on-page automatically).
# For the logo to ALSO load inside emails, set this to an absolute public URL
# (e.g. https://your-host/brand/logo.png or a logo hosted on cymate.io).
BRAND_LOGO_URL=
